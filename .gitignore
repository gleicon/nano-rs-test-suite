# =============================================================================
# NANO-RS Test Suite - Git Ignore File
# =============================================================================

# -----------------------------------------------------------------------------
# BINARIES & EXECUTABLES
# -----------------------------------------------------------------------------

# nano-rs binaries (downloaded or built locally)
bin/nano-rs
bin/nano-rs-*
examples/nano-rs
examples/nano-rs-*
*.exe
*.dll
*.so
*.dylib

# Downloaded release archives
*.tar.gz
*.tar
*.zip
*.tgz

# Sliver snapshot files
*.sliver
slivers/

# -----------------------------------------------------------------------------
# NODE.JS / NPM
# -----------------------------------------------------------------------------

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# Optional npm cache
.npm

# -----------------------------------------------------------------------------
# ENVIRONMENT & CREDENTIALS
# -----------------------------------------------------------------------------

# Environment variables
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production

# Config files with potential secrets
config.json
secrets.json
credentials.json
*.key
*.pem
*.crt

# -----------------------------------------------------------------------------
# TEST ARTIFACTS & TEMPORARY FILES
# -----------------------------------------------------------------------------

# Test logs
test-run-*.log
*.log

# Temporary test directories
tmp/
temp/
test-temp/

# Generated test configs (created at runtime)
tests/test-config-*.json

# Report backups (keep latest, ignore old)
reports/report-*.json
reports/report-*.md
!reports/latest-report.md

# Archive directory (old reports)
.archive/

# -----------------------------------------------------------------------------
# OS-SPECIFIC FILES
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.nfs*

# -----------------------------------------------------------------------------
# IDE & EDITOR FILES
# -----------------------------------------------------------------------------

# VS Code
.vscode/
*.code-workspace

# JetBrains / IntelliJ
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Neovim
*.swp
*.swo
*~
.vim/

# Emacs
*~
#*#
.#*

# -----------------------------------------------------------------------------
# BUILD & CACHE FILES
# -----------------------------------------------------------------------------

# Build output
build/
dist/
out/

# Cache directories
.cache/
.parcel-cache/

# TypeScript
*.tsbuildinfo

# -----------------------------------------------------------------------------
# DEBUG & PROFILING
# -----------------------------------------------------------------------------

# Core dumps
core
core.*

# Profiling data
*.prof

# -----------------------------------------------------------------------------
# MISC
# -----------------------------------------------------------------------------

# Coverage reports
coverage/
.nyc_output/

# Local history (various tools)
.history/
.localhistory/

